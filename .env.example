# Application settings for 98-tstlocal
# Copy this file to .env and customize for local development.
# .env is gitignored — it MUST NOT be committed to the repository.

# Application name used as the FastAPI title (default: "98-tstlocal")
# APP_NAME=98-tstlocal

# Enable debug mode (default: False)
# DEBUG=False

# Bind address for the uvicorn dev server (default: 0.0.0.0)
# HOST=0.0.0.0

# Port for the uvicorn dev server (default: 8000)
# PORT=8000
